<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us - MVMT Watches</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <!-- NAVIGATION HEADER -->
    <header class="header">
        <div class="container">
            <div class="header-content">
                <div class="logo">MVMT</div>
                
                <!-- Hamburger Menu Button -->
                <button class="hamburger" id="hamburger" aria-label="Toggle navigation menu">
                    <span class="hamburger-line"></span>
                    <span class="hamburger-line"></span>
                    <span class="hamburger-line"></span>
                </button>

                <!-- Navigation Menu -->
                <nav class="nav" id="navMenu">
                    <a href="/">Home</a>
                    <a href="#watches">Watches</a>
                    <a href="#eyewear">Eyewear</a>
                    <a href="#jewelry">Jewelry</a>
                </nav>

                <div class="header-actions">
                    <button class="search-btn">🔍</button>
                    <button class="signin-btn">Sign In</button>
                </div>
            </div>
        </div>
    </header>

    <!-- PROMO BANNER -->
    <section class="promo-banner">
        <div class="container">
            <p>BOGO: Buy One, Get One 50% Off | Code: BOGO_50</p>
        </div>
    </section>

    <!-- CONTACT HERO -->
    <section class="hero">
        <div class="hero-content">
            <h1>Contact Us</h1>
            <p>We'd love to hear from you</p>
        </div>
    </section>

    <!-- CONTACT FORM SECTION -->
    <section class="about" style="padding: 60px 0; margin-bottom: 40px;">
        <div class="container">
            <h2>Get In Touch</h2>
            <form style="max-width: 600px; margin: 40px auto; text-align: left;">
                <div style="margin-bottom: 20px;">
                    <label style="display: block; margin-bottom: 8px; font-weight: 500;">Full Name</label>
                    <input type="text" required style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 3px; font-size: 14px;">
                </div>
                
                <div style="margin-bottom: 20px;">
                    <label style="display: block; margin-bottom: 8px; font-weight: 500;">Email Address</label>
                    <input type="email" required style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 3px; font-size: 14px;">
                </div>
                
                <div style="margin-bottom: 20px;">
                    <label style="display: block; margin-bottom: 8px; font-weight: 500;">Subject</label>
                    <input type="text" required style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 3px; font-size: 14px;">
                </div>
                
                <div style="margin-bottom: 20px;">
                    <label style="display: block; margin-bottom: 8px; font-weight: 500;">Message</label>
                    <textarea required rows="6" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 3px; font-size: 14px; font-family: inherit;"></textarea>
                </div>
                
                <button type="submit" class="cta-btn" style="width: 100%;">Send Message</button>
            </form>
        </div>
    </section>

    <!-- CONTACT INFO SECTION -->
    <section class="benefits">
        <div class="container">
            <h2>How to Reach Us</h2>
            <div class="benefits-grid">
                <div class="benefit-card">
                    <div class="benefit-icon">📧</div>
                    <h3>Email</h3>
                    <p><a href="mailto:support@mvmt.com" style="color: #666; text-decoration: none;">support@mvmt.com</a></p>
                </div>
                <div class="benefit-card">
                    <div class="benefit-icon">📞</div>
                    <h3>Phone</h3>
                    <p>1-800-MVMT-HELP<br>(1-800-686-8435)</p>
                </div>
                <div class="benefit-card">
                    <div class="benefit-icon">📍</div>
                    <h3>Address</h3>
                    <p>123 Fashion Street<br>Los Angeles, CA 90001</p>
                </div>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h4>Shop</h4>
                    <ul>
                        <li><a href="#">Watches</a></li>
                        <li><a href="#">Eyewear</a></li>
                        <li><a href="#">Jewelry</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h4>Support</h4>
                    <ul>
                        <li><a href="/contact-us">Contact Us</a></li>
                        <li><a href="#">FAQ</a></li>
                        <li><a href="#">Shipping & Returns</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h4>Company</h4>
                    <ul>
                        <li><a href="#">About Us</a></li>
                        <li><a href="#">Blog</a></li>
                        <li><a href="#">Ambassadors</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h4>Follow Us</h4>
                    <div class="social-links">
                        <a href="#">Facebook</a>
                        <a href="#">Instagram</a>
                        <a href="#">Twitter</a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 MVMT. All Rights Reserved.</p>
            </div>
        </div>
    </footer>

    <!-- JavaScript for Hamburger Menu -->
    <script src="/js/script.js"></script>
</body>
</html>
