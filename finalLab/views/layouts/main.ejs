<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof pageTitle !== "undefined" ? pageTitle : "MVMT" %></title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="<%= typeof bodyClass !== "undefined" ? bodyClass : "" %>">
    <%- include("../partials/header", { activePage: typeof activePage !== "undefined" ? activePage : "" }) %>
    <%- include("../partials/flash") %>

    <%- body %>

    <footer class="footer">
        <div class="container">
            <div class="footer-bottom">
                <p>&copy; 2026 MVMT. All Rights Reserved.</p>
            </div>
        </div>
    </footer>

    <script src="/js/script.js"></script>
    <% if (typeof includeJquery !== "undefined" && includeJquery) { %>
        <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <% } %>
    <% if (typeof pageScripts !== "undefined" && pageScripts.length) { %>
        <% pageScripts.forEach(function(scriptPath) { %>
            <script src="<%= scriptPath %>"></script>
        <% }) %>
    <% } %>
</body>
</html>
