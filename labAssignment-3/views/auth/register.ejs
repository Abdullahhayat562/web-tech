<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - MVMT</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include("../partials/header", { activePage: "register" }) %>
    <%- include("../partials/flash") %>

    <main class="auth-page">
        <section class="auth-card">
            <p class="eyebrow">Create Account</p>
            <h1>Register</h1>

            <% if (errors.length > 0) { %>
                <div class="form-errors">
                    <% errors.forEach(function(error) { %>
                        <p><%= error %></p>
                    <% }) %>
                </div>
            <% } %>

            <form class="auth-form" method="POST" action="/register">
                <div class="auth-field">
                    <label for="name">Name</label>
                    <input id="name" name="name" type="text" value="<%= formData.name || '' %>" required>
                </div>
                <div class="auth-field">
                    <label for="email">Email</label>
                    <input id="email" name="email" type="email" value="<%= formData.email || '' %>" required>
                </div>
                <div class="auth-field">
                    <label for="password">Password</label>
                    <input id="password" name="password" type="password" minlength="6" required>
                </div>
                <button class="cta-btn" type="submit">Register</button>
            </form>
            <p class="auth-switch">Already have an account? <a href="/login">Login</a></p>
        </section>
    </main>

    <script src="/js/script.js"></script>
</body>
</html>
